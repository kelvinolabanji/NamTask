# ══════════════════════════════════════════════════════════════════════════════
# Nam Task — Production Environment Variables
# Copy to .env on your server. NEVER commit .env to git.
#
# Generate secrets with: openssl rand -hex 32
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Domain (update to your actual domain) ─────────────────────────────────────
API_BASE_URL=https://api.namtask.com
APP_BASE_URL=https://app.namtask.com
ALLOWED_ORIGINS=https://app.namtask.com,https://admin.namtask.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=namtask
DB_USER=namtask_user
DB_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUST be changed — minimum 32 random bytes
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_EXPIRES_IN=7d

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── File uploads ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE=5242880

# ── Business rules ────────────────────────────────────────────────────────────
COMMISSION_RATE=0.10
WITHDRAWAL_FEE=5.00
DAILY_WITHDRAWAL_LIMIT=10000.00

# ── SMS booking ───────────────────────────────────────────────────────────────
SMS_WEBHOOK_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── FNB eWallet (production) ──────────────────────────────────────────────────
# Leave blank in staging to use mock mode
FNB_API_URL=https://api.fnbnamibia.com.na/ewallet/v2
FNB_CLIENT_ID=
FNB_CLIENT_SECRET=
FNB_WEBHOOK_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Bank Windhoek (production) ────────────────────────────────────────────────
BWK_API_URL=https://api.bankwindhoek.com.na/payments/v2
BWK_API_KEY=
BWK_API_SECRET=
BWK_WEBHOOK_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
BWK_MERCHANT_ID=NAMTASK001

# ── Expo push notifications ───────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=

# Server
NODE_ENV=development
PORT=3000

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=namtask
DB_USER=namtask_user
DB_PASSWORD=namtask_pass

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Commission
COMMISSION_RATE=0.10

# SMS (Mock)
SMS_WEBHOOK_SECRET=sms_secret_key

# Admin
ADMIN_EMAIL=admin@namtask.com
ADMIN_PASSWORD=Admin@123456
